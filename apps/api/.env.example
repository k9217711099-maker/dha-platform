# Скопируйте в .env и заполните. .env НИКОГДА не коммитится (ПДн/ключи интеграций).

# --- Базовое ---
NODE_ENV=development
PORT=3001
# CORS: список origin через запятую
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Данные (Yandex Cloud, РФ) ---
DATABASE_URL=postgresql://dha:dha@localhost:5432/dha?schema=public
REDIS_URL=redis://localhost:6379

# --- Аутентификация ---
JWT_SECRET=change-me-in-prod-min-16-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
# Ключ шифрования ПДн (32 байта в base64). Сгенерировать: openssl rand -base64 32
PII_ENCRYPTION_KEY=
# OTP
OTP_LENGTH=6
OTP_TTL=300

# --- Object Storage (S3-совместимое, Yandex) для сканов документов ---
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=dha-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Интеграции (заполняются по мере подключения блоков) ---
# Bnovo: mock (in-memory, для разработки) или http (реальный API)
BNOVO_PROVIDER=mock
BNOVO_API_BASE=https://api.pms.bnovo.ru
BNOVO_API_KEY=
# CRON синхронизации каталога (по умолчанию каждые 10 минут)
BNOVO_SYNC_CRON=0 */10 * * * *
BITRIX24_WEBHOOK_URL=
# TTLock: для реального API (TTLOCK_PROVIDER=http) нужны clientId/secret из
# кабинета разработчика open.ttlock.com + аккаунт-владелец замков.
TTLOCK_PROVIDER=mock
TTLOCK_API_BASE=https://euapi.ttlock.com
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=
# get — TTLock сам генерирует код по алгоритму (БЕЗ шлюза); add — свой код (нужен шлюз/BT)
TTLOCK_PASSCODE_MODE=get
# для режима add: 3 — через шлюз, 2 — Bluetooth
TTLOCK_ADD_TYPE=3
# Активный эквайер: mock | yookassa | bspb (Банк «Санкт-Петербург») | paykeeper.
# Если не задан — определяется по YOOKASSA_PROVIDER (обратная совместимость).
PAYMENT_PROVIDER=mock
# ЮKassa: тестовый магазин на yookassa.ru → ЛК → «Тестовый магазин»;
#   shopId и секретный ключ (test_...) — там же. Webhook: POST {PUBLIC_URL}/api/payments/webhook.
YOOKASSA_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Банк «Санкт-Петербург» (интернет-эквайринг, PAYMENT_PROVIDER=bspb). Мерчант-креды
#   и сертификат — из ЛК БСПБ / письмом internet_acquiring@bspb.ru. Тест: pgtest.bspb.ru.
#   Способы оплаты (карты/СБП, «только СБП») настраиваются в админке: Настройки → Финансы.
BSPB_API_BASE=https://pgtest.bspb.ru
BSPB_MERCHANT_ID=
BSPB_USERNAME=
BSPB_PASSWORD=
BSPB_CERT_PATH=
BSPB_CERT_KEY_PATH=
# PayKeeper (PAYMENT_PROVIDER=paykeeper). Реквизиты — в ЛК PayKeeper; способы оплаты
#   (карты/СБП) настраиваются в админке: Настройки → Финансы → PayKeeper → «Настроить».
#   SERVER — адрес ЛК, SECRET — секретное слово для подписи callback.
PAYKEEPER_SERVER=
PAYKEEPER_USER=
PAYKEEPER_PASSWORD=
PAYKEEPER_SECRET=
PAYMENT_RETURN_URL=http://localhost:3000/bookings

# Публичный адрес гостевого портала (apps/web) — база для ссылок заселения
# (magic-link заезда в письмах/СМС и на стойке). На проде = https://nomero.online.
# Если не задать — берётся дефолт http://localhost:3000 и гость получит нерабочую ссылку.
GUEST_PORTAL_BASE_URL=http://localhost:3000
# Фолбэк-поллинг статусов платежей (если webhook не настроен/не дошёл). Раз в минуту.
PAYMENT_SYNC_CRON=0 * * * * *

# Фискализация чеков (54-ФЗ): none | mock | atol (АТОЛ Онлайн).
#   Нужна для эквайринга БСПБ (сам чеки не бьёт). Для ЮKassa обычно none.
FISCAL_PROVIDER=none
ATOL_API_BASE=https://online.atol.ru/possystem/v4
ATOL_LOGIN=
ATOL_PASSWORD=
ATOL_GROUP_CODE=
ATOL_INN=
ATOL_PAYMENT_ADDRESS=
ATOL_SNO=usn_income

# --- SMS / Push ---
SMS_PROVIDER=smsc
SMS_API_LOGIN=
SMS_API_PASSWORD=

# --- Распознавание паспорта ---
# mock — ручной ввод (в проде без автозаполнения); http — self-hosted Tesseract-сайдкар
# (слаб на паспорте РФ); yandex — Yandex Vision OCR, модель passport (точно, для паспорта РФ).
PASSPORT_PROVIDER=mock
PASSPORT_OCR_URL=http://localhost:8077
# Yandex Vision (PASSPORT_PROVIDER=yandex): сервисный аккаунт с ролью ai.vision.user →
# API-ключ + ID каталога. Скан уходит в Yandex Cloud (152-ФЗ: нужно согласие гостя).
YANDEX_VISION_API_KEY=
YANDEX_VISION_FOLDER_ID=
YANDEX_VISION_OCR_URL=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
# Dadata «Проверка паспорта» (список недействительных МВД) — опционально.
DADATA_API_KEY=
DADATA_SECRET=
